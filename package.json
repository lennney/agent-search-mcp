{
  "name": "agent-search-mcp",
  "version": "3.0.1",
  "description": "Free multi-engine MCP search server — 7 engines (DDG, Sogou, Bing, Baidu, Brave, Tavily, Exa), waterfall progressive search, multi-source verification, content enrichment, and CLI. Zero API keys needed.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "agent-search-mcp": "dist/index.js",
    "fasm": "dist/cli.js"
  },
  "files": [
    "dist/**",
    "scripts/**",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lennney/agent-search-mcp.git"
  },
  "homepage": "https://github.com/lennney/agent-search-mcp",
  "bugs": {
    "url": "https://github.com/lennney/agent-search-mcp/issues"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "search",
    "model-context-protocol",
    "ai-agent",
    "duckduckgo",
    "sogou",
    "bing",
    "baidu",
    "brave",
    "tavily",
    "exa",
    "free-search",
    "multi-engine"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', '755')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "tsc --watch",
    "dev": "tsc && node dist/index.js",
    "dev:http": "tsc && MODE=http PORT=3000 node dist/index.js",
    "dev:both": "tsc && MODE=both PORT=3000 node dist/index.js",
    "cli": "tsc && node dist/cli.js",
    "start": "node dist/index.js",
    "start:http": "MODE=http PORT=3000 node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "pino": "^9.0.0",
    "yaml": "^2.7.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "typescript": "^5.3.3",
    "vitest": "^3.1.3"
  }
}
